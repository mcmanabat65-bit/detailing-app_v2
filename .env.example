# Supabase — fill these in with your project's URL + anon key.
# Find them in your Supabase project → Settings → API.
# Restart `npm run dev` after changing these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Service-role key (server-only — NEVER prefix with NEXT_PUBLIC).
# Supabase → Settings → API → service_role secret. Required only for creating
# staff login accounts from the in-app Staff Access page. Bypasses RLS, so keep
# it secret and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend) — https://resend.com → API Keys
# Leave blank to disable email sending without errors.
RESEND_API_KEY=
EMAIL_FROM=Samahuzai Detailing <noreply@samahuzai.ph>
